# Quant-Sync-Server 环境变量配置
# 复制此文件为 .env 并填写实际值

# Notion API
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_STRATEGY_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_BACKTEST_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_SIGNAL_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Go Server
GOSERVER_HOST=localhost
GOSERVER_PORT=8080
GOSERVER_GRPC_PORT=50051
