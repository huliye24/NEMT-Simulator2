# Obsidian MCP Configuration
# ==============================

# Obsidian Local REST API 配置
# 1. 在 Obsidian 中安装 "Local REST API" 插件
# 2. 启用插件并复制 API Key
OBSIDIAN_API_KEY=your-obsidian-api-key-here

# Obsidian 服务器地址 (默认)
OBSIDIAN_HOST=127.0.0.1
OBSIDIAN_PORT=27124

# Obsidian Vault 名称
OBSIDIAN_VAULT=NEMT-Simulator
